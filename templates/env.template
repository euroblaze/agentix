# LUDO shared .env keys — the cross-service common set. Copy what your service needs
# into its own .env.example, then to .env.<stage> (gitignored). Service-specific keys
# (provider API keys, vault, Mollie/Odoo/Brevo, OAuth) live in each repo's .env.example.
# NEVER commit real secrets — only these dev placeholders. stag/prod FAIL FAST on them.
# Values mirror constants/cluster.yaml; see docs/env-and-secrets.md.

# ── Environment ───────────────────────────────────────────────────────────────
APP_ENV=dev                          # selects .env.<APP_ENV> (.env is fallback): dev|stag|prod

# ── Network (defaults from constants/cluster.yaml) ────────────────────────────
# Loopback alias 10.0.99.1 (never localhost). NATS for broker-connected services.
NATS_URL=nats://10.0.99.1:4222

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=dev-insecure-change-me    # prod: strong KMS-managed secret (guard refuses this default)
JWT_ALG=HS256
JWT_TTL_HOURS=24

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=                            # empty => <repo>/data/logs/app.log

# ── Locale / currency ─────────────────────────────────────────────────────────
DEFAULT_LOCALE=de                    # backend default (DACH); frontends match browser, en fallback
BILLING_CURRENCY=EUR
